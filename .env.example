# ---------------------------------------------------------------------------
# Easy 2-player online (Firebase + Vercel + Web Push) — see README_EASY_ONLINE.md
#
# NOTE ON NAMES: this project is Next.js, not Vite. Vite-style variables
# (VITE_FIREBASE_API_KEY, …) are NOT exposed to the browser by Next.js —
# the equivalent browser-exposed prefix is NEXT_PUBLIC_. Same values, Next
# names. Copy this file to .env.local for local dev, and add the same
# variables in Vercel → Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Firebase web app config (Firebase console → Project settings → Your apps → Web).
# Safe to expose in the browser — Firebase web API keys are identifiers, not secrets;
# access control comes from your Realtime Database rules.
NEXT_PUBLIC_FIREBASE_API_KEY= AIzaSyDfFgVzvxwBb5VZreLNrpIHpCP5NPRfjP8
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN= hamsa-duo-d168c.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL= https://hamsa-duo-d168c-default-rtdb.firebaseio.com/
NEXT_PUBLIC_FIREBASE_PROJECT_ID= hamsa-duo-d168c

# Web Push VAPID key pair. Generate once with:  npx web-push generate-vapid-keys
# The PUBLIC key is used by the browser to subscribe (hence NEXT_PUBLIC_);
# the PRIVATE key is used only by the serverless function — keep it secret,
# never NEXT_PUBLIC_.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BGLhCKdZeBknsCyVWtbL-VmzoDhA1ccppDoeEDz_AXFZGNJykNzXNDAw9PcVX_lLHK5m6XKRdDZIvfTCBankHrE
VAPID_PRIVATE_KEY=CMvpl0j6NKEAfSujjVZOhDyD2tQg4IzG8ryCv49blVE
# A contact URI for push services (mailto: or https:).
VAPID_SUBJECT=mailto:you@example.com
